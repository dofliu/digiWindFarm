# ── digiWindFarm Configuration ──
# Copy this file to .env and adjust as needed.

# Backend (FastAPI + Uvicorn)
BACKEND_PORT=8100
BACKEND_HOST=0.0.0.0

# Frontend (Vite dev server)
VITE_PORT=3100

# Frontend → Backend connection (used by Vite proxy and browser fallback)
VITE_API_BASE=http://localhost:8100
VITE_WS_URL=ws://localhost:8100/ws/realtime

# Modbus TCP simulator
MODBUS_PORT=5020

# Gemini API key (optional, for AI fault analysis)
# GEMINI_API_KEY=

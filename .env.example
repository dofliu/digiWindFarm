# ── digiWindFarm Configuration ──
# Copy this file to .env and adjust as needed.

# Backend (FastAPI + Uvicorn)
BACKEND_PORT=8100
BACKEND_HOST=0.0.0.0

# Frontend (Vite dev server, ignored when using Docker)
VITE_PORT=3100

# Frontend → Backend connection (used by Vite proxy and browser fallback)
VITE_API_BASE=http://localhost:8100
VITE_WS_URL=ws://localhost:8100/ws/realtime

# Modbus TCP simulator
MODBUS_PORT=5020

# SQLite database path (default: project root wind_farm_data.db)
# DB_PATH=/app/data/wind_farm_data.db

# Docker Compose: frontend exposed port (maps to nginx port 80)
FRONTEND_PORT=3100

# Gemini API key (optional, for AI fault analysis)
# GEMINI_API_KEY=
